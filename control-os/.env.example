# Control OS environment reference
#
# This file is a template only.
# - Vite reads VITE_* variables at build/dev time.
# - Node backends do not auto-load this file; export these variables via your shell,
#   service manager, container env, or deployment platform.

########################################
# Frontend (Vite / browser app)
########################################

# Baseline posture: external auth + real module APIs.
# Root App API is real-backed. All surfaces use real backends (zero fake posture).
# Production rule (ADR-0001): do not use VITE_*_API_MODE=auto. Set explicit real/fake per surface.
VITE_AUTH_MODE=external
VITE_AUTH_API_BASE_URL=http://127.0.0.1:8779
VITE_BROWSER_SESSION_PERSISTENCE=session

# Root App API: use real mode + VITE_APP_API_BASE_URL pointing at root-app-api (see deploy/production).
VITE_APP_API_MODE=real
VITE_APP_API_BASE_URL=http://127.0.0.1:8792

VITE_CLOUD_BROWSER_API_MODE=real
VITE_CLOUD_BROWSER_API_BASE_URL=http://127.0.0.1:8787

VITE_SENDING_API_MODE=real
VITE_SENDING_API_BASE_URL=http://127.0.0.1:8788

VITE_GOOGLE_ACCOUNTS_API_MODE=real
VITE_GOOGLE_ACCOUNTS_API_BASE_URL=http://127.0.0.1:8789

VITE_CALENDAR_INVITE_API_MODE=real
VITE_CALENDAR_INVITE_API_BASE_URL=http://127.0.0.1:8790

VITE_BATCH_WORKSPACE_API_MODE=real
VITE_BATCH_WORKSPACE_API_BASE_URL=http://127.0.0.1:8793

VITE_WORKSPACE_API_MODE=real
VITE_WORKSPACE_API_BASE_URL=http://127.0.0.1:8794

VITE_SESSION_API_MODE=real
VITE_SESSION_API_BASE_URL=http://127.0.0.1:8795

VITE_TASK_MANAGER_API_MODE=real
VITE_TASK_MANAGER_API_BASE_URL=http://127.0.0.1:8796

VITE_WORKER_API_BASE_URL=http://127.0.0.1:8780/api/worker
# ↑ Worker Account Factory backend (server/worker-account-api/server.mjs, port 8780).
#   When this is set, the Worker Account Factory module is fully active.
#   If VITE_WORKER_API_BASE_URL is not set, the UI will show an "unconfigured" banner.
#   Set WORKER_ACCOUNT_ADMIN_TOKEN on the server side to require auth on all mutating endpoints.

# Demo surfaces (for local testing only). Production MUST set false.
VITE_DEMO_MODE=false

# Dashboard: use root-app-api GET /api/dashboard/summary.v1_1 when true (see deploy/production/PHASE_05_DASHBOARD_V11_ROLLOUT.md).
# VITE_DASHBOARD_V11=false

########################################
# Root App API (Node: server/root-app-api/server.mjs)
########################################
# Example launch: HOST=127.0.0.1 PORT=8792
# ROOT_APP_DATA_PATH=./server/root-app-api/.root-app-data.json
#
# GET /api/cost/ledger — synthetic (default) aggregates store-shaped demo rows;
# disabled returns an empty ledger with dataSource=disabled (use until real billing export exists).
CONTROL_ROOT_APP_COST_LEDGER_MODE=synthetic

# Server-side module base URLs for root-app federation (health aggregation, GET /api/workers,
# dashboard slices). Use loopback URLs matching your dev ports, or leave unset/"" to mark a
# module as not_configured. These are separate from browser VITE_*_API_BASE_URL values.
# AUTH_API_BASE_URL=http://127.0.0.1:8779
# SENDING_API_BASE_URL=http://127.0.0.1:8788
# CLOUD_BROWSER_API_BASE_URL=http://127.0.0.1:8787
# CALENDAR_INVITE_API_BASE_URL=http://127.0.0.1:8790
# GOOGLE_ACCOUNTS_API_BASE_URL=http://127.0.0.1:8789
# TASK_MANAGER_API_BASE_URL=http://127.0.0.1:8796
# WORKSPACE_API_BASE_URL=http://127.0.0.1:8794

# Dev-only bridge. Do not use in production.
# VITE_AUTH_MODE=local
# VITE_LOCAL_AUTH_SESSION_TTL_MS=43200000

########################################
# Shared backend auth posture
########################################
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ PRODUCTION SETUP — run this ONCE to generate all required secrets:          │
# │                                                                              │
# │   node scripts/setup/generate-secrets.mjs \                                 │
# │     --email admin@yourdomain.com \                                          │
# │     --password "your-strong-password"                                       │
# │                                                                              │
# │ The script outputs ready-to-paste values for all variables below.           │
# │ Store the output in a secrets manager — NEVER commit the output.            │
# └─────────────────────────────────────────────────────────────────────────────┘

# Production posture.
# If CONTROL_AUTH_MODE is unset, backend auth now fails safe to token posture.
CONTROL_AUTH_MODE=token
# MUST REPLACE — generate with: node scripts/setup/generate-secrets.mjs
# Value shown below is a placeholder only — it will FAIL in production if left unchanged.
CONTROL_AUTH_TOKEN_SECRET=MUST_REPLACE_change-this-long-random-secret
CONTROL_AUTH_ISSUER=control-os-auth
CONTROL_AUTH_AUDIENCE=control-os-modules
CONTROL_AUTH_ACCESS_TOKEN_TTL_SEC=900
CONTROL_AUTH_REFRESH_TOKEN_TTL_SEC=604800
CONTROL_AUTH_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
# For HTTPS production replace with your real origin, e.g.:
# CONTROL_AUTH_CORS_ALLOWED_ORIGINS=https://app.example.com
CONTROL_AUTH_REFRESH_COOKIE_NAME=control_os_refresh
CONTROL_AUTH_REFRESH_COOKIE_PATH=/api/auth
CONTROL_AUTH_REFRESH_COOKIE_SAMESITE=Lax
# Required for HTTPS production: set to true so the refresh cookie is only sent over HTTPS.
# The auth server auto-detects HTTPS via X-Forwarded-Proto when this is unset, but setting
# it explicitly is strongly recommended for production deployments behind a TLS terminator.
CONTROL_AUTH_REFRESH_COOKIE_SECURE=true

# Dev-only bridge. Do not use in production.
# CONTROL_AUTH_MODE=dev_local
# CONTROL_AUTH_DEV_LOCAL_ENABLE=true
# CONTROL_AUTH_DEV_LOCAL_LOGIN_ENABLE=true
# CONTROL_AUTH_DEV_LOCAL_PASSWORD=change-me-dev-only
# CONTROL_AUTH_DEV_LOCAL_ALLOWED_ROLES=admin,manager,lead,worker,viewer

########################################
# Minimal abuse / rate protection
########################################

# Request correlation + lifecycle posture
CONTROL_REQUEST_ID_HEADER=x-request-id
CONTROL_CORRELATION_ID_HEADER=x-correlation-id
CONTROL_TRUST_INCOMING_REQUEST_IDS=true
CONTROL_REQUEST_LOG_ENABLE=true
CONTROL_SHUTDOWN_GRACE_MS=15000
CONTROL_DRAIN_POLL_MS=250

# Optional when running behind a trusted reverse proxy.
# CONTROL_RATE_LIMIT_TRUST_PROXY=true

# Built-in auth protections.
CONTROL_RATE_LIMIT_AUTH_LOGIN_MAX=10
CONTROL_RATE_LIMIT_AUTH_LOGIN_WINDOW_MS=60000
CONTROL_RATE_LIMIT_AUTH_REFRESH_MAX=30
CONTROL_RATE_LIMIT_AUTH_REFRESH_WINDOW_MS=300000

# High-impact module writes / dispatch submits.
CONTROL_RATE_LIMIT_GOOGLE_ACCOUNTS_WRITE_MAX=20
CONTROL_RATE_LIMIT_GOOGLE_ACCOUNTS_WRITE_WINDOW_MS=300000
CONTROL_RATE_LIMIT_CLOUD_BROWSER_WRITE_MAX=30
CONTROL_RATE_LIMIT_CLOUD_BROWSER_WRITE_WINDOW_MS=300000
CONTROL_RATE_LIMIT_SENDING_CONFIG_WRITE_MAX=20
CONTROL_RATE_LIMIT_SENDING_CONFIG_WRITE_WINDOW_MS=300000
CONTROL_RATE_LIMIT_SENDING_DISPATCH_MAX=30
CONTROL_RATE_LIMIT_SENDING_DISPATCH_WINDOW_MS=60000
CONTROL_RATE_LIMIT_CALENDAR_WRITE_MAX=20
CONTROL_RATE_LIMIT_CALENDAR_WRITE_WINDOW_MS=300000
CONTROL_RATE_LIMIT_CALENDAR_DISPATCH_MAX=30
CONTROL_RATE_LIMIT_CALENDAR_DISPATCH_WINDOW_MS=60000
CONTROL_RATE_LIMIT_CALENDAR_WEBHOOK_MAX=240
CONTROL_RATE_LIMIT_CALENDAR_WEBHOOK_WINDOW_MS=60000

########################################
# Auth backend
########################################

HOST=127.0.0.1
PORT=8779
CONTROL_AUTH_DATA_PATH=./server/auth-api/.auth-data.json

# User directory for the auth-api.
# Format: JSON array of user objects, e.g.:
#   CONTROL_AUTH_USERS_JSON=[{"id":"u1","email":"admin@example.com","name":"Admin","role":"admin","passwordHash":"<scrypt-hash>"}]
#
# Production strategy options:
#   1. Environment injection — export CONTROL_AUTH_USERS_JSON as a shell/service-manager env var with
#      the full JSON array. Never commit real credentials to this file.
#   2. External user store — replace the user lookup in server/auth-api/auth-store.mjs with a call to
#      your identity provider (LDAP, SSO, etc.) and remove this var entirely.
#   3. Secret manager — mount the value from Vault/AWS Secrets Manager/Kubernetes Secret at runtime.
#
# For local development only — leave empty; use CONTROL_AUTH_MODE=dev_local instead.
# For production: run `node scripts/setup/generate-secrets.mjs` to generate a hashed user.
# Example (password is hashed with scrypt — never store plaintext):
#   CONTROL_AUTH_USERS_JSON=[{"id":"u1","email":"admin@example.com","name":"Admin","role":"admin","passwordHash":"scrypt$<salt>$<derived>"}]
CONTROL_AUTH_USERS_JSON=[]

########################################
# Shared browser API CORS
########################################

# Comma-separated browser origins allowed to call module APIs from the browser.
CONTROL_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
# For HTTPS production replace with your real origin, e.g.:
# CONTROL_CORS_ALLOWED_ORIGINS=https://app.example.com

# If running Tauri dev, add the active Tauri frontend origin (for example, `http://127.0.0.1:1420` after standardization) to the allowed origins list.
# CSP allowlisting is also required for desktop (ADR-0002).

########################################
# Shared secret persistence posture
########################################

# Required when any persisted provider/API/OAuth secret is enabled below.
# MUST REPLACE — generate with: node scripts/setup/generate-secrets.mjs
# Value shown below is a placeholder only — it will FAIL in production if left unchanged.
CONTROL_SECRET_MASTER_KEY=MUST_REPLACE_change-this-long-random-secret-master-key

# Dev-only escape hatch for plaintext persisted secrets. Do not use in production.
# CONTROL_SECRET_ALLOW_PLAINTEXT_DEV=true

########################################
# Cloud Browser backend
########################################

# Example launch posture:
# HOST=127.0.0.1
# PORT=8787
CLOUD_BROWSER_DATA_PATH=./server/cloud-browser-api/.cloud-browser-data.json
CLOUD_BROWSER_EXECUTION_QUEUE_PATH=./server/cloud-browser-api/.cloud-browser-execution-queue.json
CLOUD_BROWSER_PROVIDER_PERSIST_TOKEN=false

########################################
# Sending backend
########################################

# Example launch posture:
# HOST=127.0.0.1
# PORT=8788
SENDING_DATA_PATH=./server/sending-api/.sending-data.json
SENDING_QUEUE_PATH=./server/sending-api/.sending-queue.json

# Legitimate, allowlisted sending only.
SENDING_ALLOWED_RECIPIENT_DOMAINS=example.com

SENDING_PROVIDER_PERSIST_TOKEN=false
SENDING_PROVIDER_PERSIST_BASIC_AUTH_SECRET=false
SENDING_SMTP_PERSIST_SECRET=false
SENDING_DSN_MAILBOX_PERSIST_SECRET=false

# Google Accounts boundary for Gmail API transport.
# Sending no longer reads Google Accounts files directly for Gmail API access;
# it uses google-accounts-api broker endpoints with a backend-only service JWT.
# Important: this bearer token is service-specific. Sending and Calendar Invite
# should each receive their own signed JWT with only the grants they need.
GOOGLE_ACCOUNTS_API_BASE_URL=http://127.0.0.1:8789
# CONTROL_SERVICE_JWT_BEARER_TOKEN=change-me-service-jwt

# Internal execution lease/callback foundation (Go pilot; Gmail API send_delivery_attempt only)
# sending-api owns the durable queue and verifies worker service JWTs for:
# - internal claim/lease
# - internal lease release/requeue
# - internal execution-result callback
# Workers must not read or mutate SENDING_QUEUE_PATH directly.
# SENDING_INTERNAL_CALLBACK_SERVICE_JWT_AUDIENCE=sending-execution-callback

# Optional Gmail API endpoint override for controlled environments.
# Note: OAuth token exchange is performed by google-accounts-api via its broker.
# SENDING_GMAIL_API_BASE_URL=https://gmail.googleapis.com
# Note: SMTP and generic HTTP JSON Sending provider behavior are not part of this broker path.

# Optional bounded workers
# PRODUCTION: set SENDING_SEND_WORKER_ENABLE=true to allow the sending API to actually
# deliver email. Without this, dispatches are queued but never executed.
# Requires at least one provider to be configured (SMTP, Gmail API, or HTTP JSON).
SENDING_POLL_WORKER_ENABLE=false
SENDING_SEND_WORKER_ENABLE=false
SENDING_DSN_WORKER_ENABLE=false

# DSN mailbox / IMAP follow-up evidence collection
# Gmail-first follow-up automation reuses this mailbox poll seam and correlates
# later strong DSN/mailbox evidence back to Gmail API attempts by persisted
# RFC Message-ID.
# Enable only when you have a real mailbox you control for receiving bounce/DSN notices.
# SENDING_DSN_MAILBOX_ENABLED=true
# SENDING_DSN_MAILBOX_HOST=imap.gmail.com
# SENDING_DSN_MAILBOX_PORT=993
# SENDING_DSN_MAILBOX_SECURE=true
# SENDING_DSN_MAILBOX_AUTH_MODE=basic_auth
# Note: oauth2_ref is not implemented for DSN mailbox polling in this slice.
# SENDING_DSN_MAILBOX_USERNAME=mailer-daemon-monitor@example.com
# SENDING_DSN_MAILBOX_PASSWORD=change-me-or-set-via-config
# SENDING_DSN_MAILBOX_FOLDER=INBOX
# SENDING_DSN_MAILBOX_POLL_INTERVAL_MS=60000
# SENDING_DSN_MAILBOX_BATCH_SIZE=10
#
# Local/smoke-only mailbox fixture seam for deterministic validation.
# Do not use for real mailbox validation or production.
# SENDING_DSN_MAILBOX_FIXTURE_PATH=./.tmp/dsn-mailbox-fixture.json

########################################
# Google Accounts backend
########################################

# Example launch posture:
# HOST=127.0.0.1
# PORT=8789
GOOGLE_ACCOUNTS_DATA_PATH=./server/google-accounts-api/.google-accounts-data.json
GOOGLE_ACCOUNTS_PERSIST_SECRETS=false

# Phase-1 Token Broker (service-only; UI must never call broker endpoints)
# Services authenticate to broker endpoints using a signed service JWT (RS256).
# REQUIRED for Gmail API sending and Calendar Invite Google Calendar integration.
#
# Generate RS256 key pair: node scripts/setup/generate-secrets.mjs
# Then set:
#   CONTROL_SERVICE_JWT_PUBLIC_KEY_PEM  → on google-accounts-api process
#   CONTROL_SERVICE_JWT_PRIVATE_KEY_PEM → on sending-api + calendar-invite-api processes
#
CONTROL_SERVICE_JWT_ISSUER=control-os-service-auth
CONTROL_SERVICE_JWT_AUDIENCE=google-accounts-broker
# Public key in PEM format used to verify service JWTs.
# Tip: store as a quoted value with \n escapes when exporting via shell/env tooling.
# CONTROL_SERVICE_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Sending's internal execution callback reuses the same issuer/public-key
# verification inputs, but uses its own audience via
# `SENDING_INTERNAL_CALLBACK_SERVICE_JWT_AUDIENCE`.
# Services that mint their own signed service JWTs, such as the Go Sending
# worker pilot, also need the matching private key:
# CONTROL_SERVICE_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

########################################
# Sending Go worker pilot
########################################

# Optional pilot-scoped Go execution worker for Gmail API send_delivery_attempt.
# It claims/release tasks over HTTP from sending-api and never reads the durable queue file directly.
# SENDING_GO_WORKER_HOST=127.0.0.1
# SENDING_GO_WORKER_PORT=8791
# SENDING_GO_WORKER_SERVICE_ID=sending-worker-go-pilot
# SENDING_GO_WORKER_SERVICE_ENV=local_dev
# SENDING_GO_WORKER_INSTANCE_ID=dev-worker-001
# SENDING_GO_WORKER_WORKER_ID=sending-worker-go-pilot
# SENDING_GO_WORKER_ENVIRONMENT_ID=go-worker-pool
# SENDING_GO_WORKER_MAX_IN_FLIGHT=2
# SENDING_GO_WORKER_CLAIM_LIMIT=2
# SENDING_GO_WORKER_CLAIM_INTERVAL_MS=2000
# SENDING_GO_WORKER_REQUEST_TIMEOUT_MS=15000
# SENDING_GO_WORKER_SUBMIT_TIMEOUT_MS=15000
# SENDING_GO_WORKER_SHUTDOWN_GRACE_MS=15000
# SENDING_GO_WORKER_RELEASE_DELAY_MS=5000
# SENDING_API_BASE_URL=http://127.0.0.1:8788

# Optional Google OAuth token endpoint override for controlled test environments.
# GOOGLE_ACCOUNTS_GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_ACCOUNTS_BROKER_TOKEN_TIMEOUT_MS=15000

########################################
# Local isolated Sending worker validation profile
########################################

# Opt-in launcher profile:
# npm run dev:sending-worker-live
#
# This starts only:
# - auth-api
# - google-accounts-api
# - sending-api
# - sending-go-worker-pilot
#
# Defaults for that profile:
# - Auth API: 8879
# - Sending API: 8888
# - Google Accounts API: 8889
# - Sending Go Worker: 8891
# - Data root: ./.dev-data/sending-worker-live
#
# Optional overrides:
# CONTROL_DEV_STACK_PROFILE=sending_worker_live
# CONTROL_DEV_AUTH_PORT=8879
# CONTROL_DEV_SENDING_PORT=8888
# CONTROL_DEV_GOOGLE_ACCOUNTS_PORT=8889
# CONTROL_DEV_SENDING_GO_WORKER_PORT=8891
# CONTROL_DEV_DATA_ROOT=./.dev-data/sending-worker-live

########################################
# Calendar Invite backend
########################################

# Example launch posture:
# HOST=127.0.0.1
# PORT=8790
CALENDAR_INVITE_DATA_PATH=./server/calendar-invite-api/.calendar-invite-data.json
CALENDAR_INVITE_QUEUE_PATH=./server/calendar-invite-api/.calendar-invite-queue.json

# Google Accounts boundary (Phase-1 broker integration)
# Calendar Invite no longer reads Google Accounts store files directly; it calls google-accounts-api broker endpoints.
# Important: this bearer token is service-specific. Calendar Invite should use
# its own signed JWT, not reuse Sending's token by default.
GOOGLE_ACCOUNTS_API_BASE_URL=http://127.0.0.1:8789
# Service-only JWT bearer token used to call broker endpoints (RS256, ~30min TTL).
# CONTROL_SERVICE_JWT_BEARER_TOKEN=change-me-service-jwt

# Legitimate, allowlisted invite guests only.
CALENDAR_INVITE_ALLOWED_ATTENDEE_DOMAINS=example.com
CALENDAR_INVITE_MAX_ATTENDEES=25
CALENDAR_INVITE_PUSH_WEBHOOK_ADDRESS=https://calendar.example.com/api/calendar-invite/google/webhook
CALENDAR_INVITE_PUSH_TOKEN_SECRET=change-this-calendar-push-secret
# Dev-only escape hatch. Generates an in-process random fallback when the explicit secret is absent.
# CALENDAR_INVITE_ALLOW_DEV_PUSH_TOKEN_FALLBACK=true
CALENDAR_INVITE_PUSH_STALE_MS=900000
CALENDAR_INVITE_SYNC_WORKER_LIMIT=10

# Optional Google endpoint overrides for controlled test environments.
# Note: token exchange is performed by google-accounts-api via its broker in this posture.
# CALENDAR_INVITE_GOOGLE_API_BASE_URL=https://www.googleapis.com
# Note: Calendar `email_invite` mode is not implemented in this phase; this section is for the Google Calendar provider path.

########################################
# Session API backend
########################################

# Example launch posture:
# HOST=127.0.0.1
# PORT=8795
SESSION_API_DATA_FILE=./server/session-api/data/session-data.json

# Admin token used to authorize device enrollment and force-release operations.
# MUST REPLACE in production. Never use the default value in a real deployment.
# Generate with: node scripts/setup/generate-secrets.mjs
# MUST REPLACE:
SESSION_SECRET=MUST_REPLACE_change-this-long-random-session-secret
# MUST REPLACE:
ADMIN_TOKEN=MUST_REPLACE_change-this-long-random-admin-token
# CORS origin for session-api — MUST REPLACE in production with your SPA origin (e.g. https://control.example.com).
# Defaults to '*' (open) when not set — only acceptable for local dev.
# SESSION_API_CORS_ORIGIN=https://control.example.com

########################################
# Smoke / verify (Node scripts under scripts/smoke/*.mjs)
########################################
# Transient network flakes (UND_ERR_*, slow CI): extra fetch attempts after the first try.
# SMOKE_FETCH_RETRIES=2
# SMOKE_FETCH_RETRY_BASE_MS=400
# Poll interval and total wait for startServer health probes.
# SMOKE_HEALTH_POLL_MS=250
# SMOKE_HEALTH_TIMEOUT_MS=15000
# Max wait for child process /health before smoke fails the run.
# SMOKE_SERVER_READY_TIMEOUT_MS=15000
# SIGTERM to SIGKILL grace when tearing down spawned API processes.
# SMOKE_SERVER_STOP_GRACE_MS=5000
